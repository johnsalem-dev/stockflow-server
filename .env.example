# Server
PORT=3000
NODE_ENV=development
LOG_LEVEL=info

# PostgreSQL (required - matches docker-compose)
# Never commit .env with real credentials
DB_HOST=localhost
DB_PORT=5432
DB_USERNAME=postgres
DB_PASSWORD=1234
DB_DATABASE=inventory

# Prisma: postgresql://USER:PASSWORD@HOST:PORT/DATABASE
DATABASE_URL=postgresql://postgres:1234@localhost:5432/inventory
