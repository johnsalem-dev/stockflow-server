generator client {
  provider = "prisma-client-js"
  previewFeatures = ["views"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ENUM
enum RefSource {
  MAPLE
  IGP_BOOK
}

model Category {
  id        Int     @id @default(autoincrement()) @db.SmallInt @map("id")
  name      String  @unique @db.VarChar(50) @map("name")

  items     Item[]

  @@map("categories")
}

model Department {
  id        Int        @id @default(autoincrement()) @db.SmallInt @map("id")
  name      String     @unique @db.VarChar(50) @map("name")

  employees Employee[]

  @@map("departments")
}

model Employee {
  id            Int      @id @default(autoincrement()) @map("id")
  name          String   @db.VarChar(100) @map("name")

  departmentId  Int?     @db.SmallInt @map("department_id")
  department    Department? @relation(fields: [departmentId], references: [id])

  issuances     Issuance[]

  @@map("employees")
}

model Supplier {
  id        Int       @id @default(autoincrement()) @map("id")
  name      String    @unique @db.VarChar(100) @map("name")
  purchases Purchase[]

  @@map("suppliers")
}

model Item {
  id          Int       @id @default(autoincrement()) @map("id")
  categoryId  Int?      @db.SmallInt @map("category_id")
  category    Category? @relation(fields: [categoryId], references: [id])

  description String    @db.VarChar(255) @map("description")
  uom         String    @db.VarChar(20)  @map("uom")
  createdAt   DateTime  @default(now())  @map("created_at")

  purchases   Purchase[]
  issuances   Issuance[]

  @@map("items")
}

model Purchase {
  id           Int       @id @default(autoincrement()) @map("id")
  purchaseDate DateTime  @db.Date @map("purchase_date")

  itemId       Int @map("item_id")
  item         Item @relation(fields: [itemId], references: [id])

  supplierId   Int @map("supplier_id")
  supplier     Supplier @relation(fields: [supplierId], references: [id])

  sourceType   RefSource @map("source_type")
  referenceNo  String    @db.VarChar(50) @map("reference_no")

  quantity     Decimal   @db.Decimal(12,2) @map("quantity")
  rate         Decimal?  @db.Decimal(12,2) @map("rate")

  createdAt    DateTime  @default(now()) @map("created_at")

  @@map("purchases")
}

model Issuance {
  id           Int       @id @default(autoincrement()) @map("id")
  issuanceDate DateTime  @db.Date @map("issuance_date")

  itemId       Int @map("item_id")
  item         Item @relation(fields: [itemId], references: [id])

  employeeId   Int @map("employee_id")
  employee     Employee @relation(fields: [employeeId], references: [id])

  sourceType   RefSource @map("source_type")
  referenceNo  String    @db.VarChar(50) @map("reference_no")

  quantity     Decimal   @db.Decimal(12,2) @map("quantity")
  remarks      String?   @db.Text @map("remarks")
  postedBy     String?   @db.VarChar(100) @map("posted_by")

  createdAt    DateTime  @default(now()) @map("created_at")

  @@map("issuances")
}

view InventorySummary {
  item_code       Int
  group_item      String?
  description     String
  uom             String
  total_purchased Decimal?
  total_issued    Decimal?
  current_balance Decimal?
}