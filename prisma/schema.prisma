generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["views"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ENUM
enum RefSource {
  MAPLE
  IGP_BOOK
}

model Category {
  id   Int    @id @default(autoincrement()) @map("id") @db.SmallInt
  name String @unique @map("name") @db.VarChar(50)

  emoji       String? @map("emoji") @db.VarChar(20) // Emojis can have long unicode sequences
  code        String  @unique @map("code") @db.VarChar(20)
  description String? @map("description") @db.Text

  departmentId Int?        @map("department_id") @db.SmallInt
  department   Department? @relation(fields: [departmentId], references: [id])

  items Item[]

  @@map("categories")
}

model Department {
  id          Int     @id @default(autoincrement()) @map("id") @db.SmallInt
  name        String  @unique @map("name") @db.VarChar(50)
  code        String  @unique @map("code") @db.VarChar(10)
  description String? @map("description") @db.Text

  headId Int?      @unique @map("head_id") @db.SmallInt
  head   Employee? @relation("DepartmentHead", fields: [headId], references: [id])

  employees  Employee[] @relation("DepartmentMembers")
  categories Category[]

  @@map("departments")
}

model Employee {
  id           Int         @id @default(autoincrement()) @map("id")
  fullName     String      @map("full_name") @db.VarChar(100) 
  employeeId   String      @unique @map("employee_id") @db.VarChar(20)
  email        String      @unique @map("email") @db.VarChar(255)
  
  designation  String      @map("designation") @db.VarChar(100)

  departmentId Int?        @map("department_id") @db.SmallInt
  department   Department? @relation("DepartmentMembers", fields: [departmentId], references: [id])
  
  managedDept  Department? @relation("DepartmentHead")
  issuances    Issuance[]

  @@map("employees")
}

model Supplier {
  id        Int        @id @default(autoincrement()) @map("id")
  name      String     @unique @map("name") @db.VarChar(100)
  purchases Purchase[]

  @@map("suppliers")
}

model Item {
  id         Int       @id @default(autoincrement()) @map("id")
  categoryId Int?      @map("category_id") @db.SmallInt
  category   Category? @relation(fields: [categoryId], references: [id])

  description String   @map("description") @db.VarChar(255)
  uom         String   @map("uom") @db.VarChar(20)
  createdAt   DateTime @default(now()) @map("created_at")

  purchases Purchase[]
  issuances Issuance[]

  @@map("items")
}

model Purchase {
  id           Int      @id @default(autoincrement()) @map("id")
  purchaseDate DateTime @map("purchase_date") @db.Date

  itemId Int  @map("item_id")
  item   Item @relation(fields: [itemId], references: [id])

  supplierId Int      @map("supplier_id")
  supplier   Supplier @relation(fields: [supplierId], references: [id])

  sourceType  RefSource @map("source_type")
  referenceNo String    @map("reference_no") @db.VarChar(50)

  quantity Decimal  @map("quantity") @db.Decimal(12, 2)
  rate     Decimal? @map("rate") @db.Decimal(12, 2)

  createdAt DateTime @default(now()) @map("created_at")

  @@map("purchases")
}

model Issuance {
  id           Int      @id @default(autoincrement()) @map("id")
  issuanceDate DateTime @map("issuance_date") @db.Date

  itemId Int  @map("item_id")
  item   Item @relation(fields: [itemId], references: [id])

  employeeId Int      @map("employee_id")
  employee   Employee @relation(fields: [employeeId], references: [id])

  sourceType  RefSource @map("source_type")
  referenceNo String    @map("reference_no") @db.VarChar(50)

  quantity Decimal @map("quantity") @db.Decimal(12, 2)
  remarks  String? @map("remarks") @db.Text
  postedBy String? @map("posted_by") @db.VarChar(100)

  createdAt DateTime @default(now()) @map("created_at")

  @@map("issuances")
}

view InventorySummary {
  item_code       Int
  group_item      String?
  description     String
  uom             String
  total_purchased Decimal?
  total_issued    Decimal?
  current_balance Decimal?
}
